rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: bundles
    // Fields: name (string), dataAmount (string), price (number), network (string), active (bool), externalPlanId (string, optional)
    //
    // Collection: orders
    // Fields: customerPhone (string), customerNetwork (string), bundleId (string), 
    //         bundleName (string), price (number), status (string), 
    //         paymentMethod (string), transactionId (string), createdAt (timestamp),
    //         externalOrderId (string, optional), externalResponse (string, optional)
    //
    // Collection: users
    // Fields: email (string), role (string)
    //
    // ===============================================================

    // Helper Functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function getAuthEmail() {
      return isAuthenticated() && ("email" in request.auth.token) ? request.auth.token.email : "";
    }

    function isAdmin() {
      return isAuthenticated() &&
             "email" in request.auth.token && (
               (request.auth.token.email.lower() == "jeffreybonneya@gmail.com") ||
               (request.auth.token.email.lower() == "emmagyapong62@gmail.com")
             );
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isValidEmail(email) {
      return email is string && email.size() >= 3 && email.matches("^[^@]+@[^@]+\\.[^@]+$");
    }

    function isValidPhone(phone) {
      return phone is string && phone.size() >= 10 && phone.size() <= 15;
    }

    // Domain Validators
    function isValidBundle(data) {
      return data.keys().hasAll(['name', 'dataAmount', 'price', 'network']) &&
             data.name is string && data.name.size() < 200 &&
             data.dataAmount is string && data.dataAmount.size() < 100 &&
             data.price is number && data.price > 0 &&
             data.network in ['MTN', 'Telecel', 'AirtelTigo', 'FC Mobile', 'FC Mobile Points', 'FC Mobile Silver'] &&
             (!('externalPlanId' in data) || data.externalPlanId == null || data.externalPlanId is string) &&
             (!('category' in data) || data.category is string);
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['email', 'phone', 'network', 'bundle', 'amount', 'status', 'createdAt']) &&
             isValidEmail(data.email) &&
             data.phone is string &&
             data.network is string &&
             data.bundle is string &&
             data.amount is number && data.amount > 0 &&
             data.status in ['paid', 'completed', 'failed', 'pending', 'processing', 'delivered', 'pending_payment', 'unpaid', 'accepted', 'declined', 'checkout_unpaid', 'success'] &&
             data.createdAt is timestamp &&
             (!('reference' in data) || data.reference is string) &&
             (!('userId' in data) || data.userId is string) &&
             (!('customerName' in data) || data.customerName is string) &&
             (!('paymentStatus' in data) || data.paymentStatus is string) &&
             (!('paymentMethod' in data) || data.paymentMethod is string) &&
             (!('type' in data) || data.type in ['data', 'stream', 'system']) &&
             (!('streamType' in data) || data.streamType in ['live', 'onetime']) &&
             (!('streamStatus' in data) || data.streamStatus in ['pending', 'pending_approval', 'approved', 'rejected']) &&
             (!('metadata' in data) || data.metadata is map) &&
             (!('agentId' in data) || data.agentId is string) &&
             (!('agent_id' in data) || data.agent_id is string) &&
             (!('agentName' in data) || data.agentName is string) &&
             (!('agent_name' in data) || data.agent_name is string) &&
             (!('wholesalePrice' in data) || data.wholesalePrice is number) &&
             (!('wholesale_price' in data) || data.wholesale_price is number) &&
             (!('agentPrice' in data) || data.agentPrice is number) &&
             (!('agent_price' in data) || data.agent_price is number) &&
             (!('profit' in data) || data.profit is number) &&
             (!('agent_profit' in data) || data.agent_profit is number) &&
             (!('profitAwarded' in data) || data.profitAwarded is bool) &&
             (!('profit_credited' in data) || data.profit_credited is bool) &&
             (!('reportedToAdmin' in data) || data.reportedToAdmin is bool) &&
             (!('agentReportReason' in data) || data.agentReportReason is string) &&
             (!('recipientUsername' in data) || data.recipientUsername is string) &&
             (!('fcUserId' in data) || data.fcUserId is string) &&
             (!('fcUsername' in data) || data.fcUsername is string);
    }

    function isValidUser(data) {
      return data.keys().hasAll(['email', 'fullName', 'role']) &&
             isValidEmail(data.email) &&
             data.fullName is string && data.fullName.size() > 0 &&
             data.role in ['admin', 'user'] &&
             (!('phoneNumber' in data) || isValidPhone(data.phoneNumber)) &&
             (!('walletBalance' in data) || data.walletBalance is number) &&
             (!('isAgent' in data) || data.isAgent is bool);
    }

    function isValidAgent(data) {
      return data.keys().hasAll(['id', 'agent_name', 'agent_slug', 'momo_name', 'momo_number', 'profit_balance', 'created_at']) &&
             data.id is string &&
             data.agent_name is string && data.agent_name.size() > 0 && data.agent_name.size() < 100 &&
             data.agent_slug is string && data.agent_slug.size() > 0 && data.agent_slug.size() < 100 &&
             data.momo_name is string && data.momo_name.size() > 0 && data.momo_name.size() < 100 &&
             data.momo_number is string && data.momo_number.size() >= 10 && data.momo_number.size() <= 15 &&
             data.profit_balance is number &&
             data.created_at is timestamp &&
             (!('prices' in data) || data.prices is map);
    }

    function isValidAgentOrder(data) {
      return data.keys().hasAll(['id', 'agent_id', 'customer_details', 'wholesale_price', 'agent_price', 'profit', 'status', 'created_at']) &&
             data.id is string &&
             data.agent_id is string &&
             data.customer_details is map &&
             data.wholesale_price is number && data.wholesale_price >= 0 &&
             data.agent_price is number && data.agent_price >= 0 &&
             data.profit is number &&
             data.status is string &&
             data.created_at is timestamp;
    }

    function isValidProfitRequest(data) {
      return data.keys().hasAll(['agent_id', 'withdrawal_amount', 'status', 'created_at']) &&
             data.agent_id is string &&
             data.withdrawal_amount is number && data.withdrawal_amount > 0 &&
             data.status in ['pending', 'Seen'] &&
             data.created_at is timestamp &&
             (!('agent_name' in data) || data.agent_name is string) &&
             (!('momo_name' in data) || data.momo_name is string) &&
             (!('momo_number' in data) || data.momo_number is string);
    }

    function isValidClientUserUpdate(incoming, existing) {
       return incoming.role == existing.role &&
              (!('walletBalance' in incoming) || incoming.walletBalance <= existing.get('walletBalance', 0));
    }

    function isValidComplaint(data) {
      return data.keys().hasAll(['userId', 'userEmail', 'message', 'status', 'createdAt']) &&
             data.userId is string &&
             isValidEmail(data.userEmail) &&
             data.message is string && data.message.size() > 0 && data.message.size() < 1000 &&
             data.status in ['open', 'resolved'] &&
             data.createdAt is timestamp &&
             (!('orderId' in data) || data.orderId is string) &&
             (!('subject' in data) || data.subject is string) &&
             (!('userName' in data) || data.userName is string) &&
             (!('adminReply' in data) || data.adminReply is string);
    }

    function isValidWalletTransaction(data) {
      return data.keys().hasAll(['userId', 'amount', 'type', 'status', 'reference', 'createdAt']) &&
             data.userId is string &&
             data.amount is number && data.amount > 0 &&
             data.type in ['topup', 'purchase'] &&
             data.status in ['pending', 'success', 'failed'] &&
             data.reference is string &&
             data.createdAt is timestamp;
    }

    function isValidMessage(data) {
      return data.keys().hasAll(['userId', 'userEmail', 'userName', 'message', 'status', 'createdAt']) &&
             data.userId is string &&
             isValidEmail(data.userEmail) &&
             data.userName is string && data.userName.size() > 0 &&
             data.message is string && data.message.size() > 0 &&
             data.status in ['unread', 'read'] &&
             data.createdAt is timestamp &&
             (!('subject' in data) || (data.subject is string && data.subject.size() < 100));
    }

    function isValidStreamAccess(data) {
      return data.keys().hasAll(['userId', 'userName', 'userEmail', 'status', 'referenceCode', 'amountPaid', 'createdAt']) &&
             data.userId is string &&
             data.userName is string &&
             isValidEmail(data.userEmail) &&
             data.status in ['pending', 'approved', 'revoked'] &&
             data.referenceCode is string &&
             data.amountPaid is number &&
             data.createdAt is timestamp;
    }

    // Rules
    match /bundles/{bundleId} {
      allow read: if true; // Publicly viewable
      allow create, update, delete: if true;
    }

    match /orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && (
        ('userId' in resource.data && resource.data.userId == request.auth.uid) || 
        ('agent_id' in resource.data && resource.data.agent_id == request.auth.uid) || 
        ('agentId' in resource.data && resource.data.agentId == request.auth.uid) || 
        (getAuthEmail() != "" && 'email' in resource.data && (resource.data.email == getAuthEmail() || resource.data.email.lower() == getAuthEmail().lower()))
      ));
      allow create: if isAuthenticated() && isValidOrder(request.resource.data) && (
        ('userId' in request.resource.data && request.resource.data.userId == request.auth.uid) || 
        (getAuthEmail() != "" && 'email' in request.resource.data && (request.resource.data.email == getAuthEmail() || request.resource.data.email.lower() == getAuthEmail().lower()))
      );
      allow update: if isAdmin() || (
        isAuthenticated() && 
        isValidOrder(request.resource.data) && (
          // EITHER: An agent updating reporting fields
          (
            (('agent_id' in resource.data && resource.data.agent_id == request.auth.uid) || 
             ('agentId' in resource.data && resource.data.agentId == request.auth.uid)) &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reportedToAdmin', 'agentReportReason'])
          ) ||
          // OR: The buyer/agent updating payment status upon successful Paystack completion
          (
            (
              ('userId' in resource.data && resource.data.userId == request.auth.uid) || 
              ('agent_id' in resource.data && resource.data.agent_id == request.auth.uid) || 
              ('agentId' in resource.data && resource.data.agentId == request.auth.uid) || 
              (getAuthEmail() != "" && 'email' in resource.data && (resource.data.email == getAuthEmail() || resource.data.email.lower() == getAuthEmail().lower()))
            ) &&
            request.resource.data.diff(resource.data).affectedKeys().hasOnly(['paymentStatus', 'reference', 'profitAwarded', 'profit_credited', 'status'])
          )
        )
      );
      allow delete: if isAdmin() || (
        isAuthenticated() && (
          ('userId' in resource.data && resource.data.userId == request.auth.uid) || 
          ('agent_id' in resource.data && resource.data.agent_id == request.auth.uid) || 
          ('agentId' in resource.data && resource.data.agentId == request.auth.uid) || 
          (getAuthEmail() != "" && 'email' in resource.data && (resource.data.email == getAuthEmail() || resource.data.email.lower() == getAuthEmail().lower()))
        )
      );
    }

    match /users/{userId} {
      allow read: if isOwner(userId) || isAdmin();
      allow create: if isAuthenticated() && isValidUser(request.resource.data) && (request.resource.data.role == 'user' || isAdmin());
      allow update: if isAdmin() || (isOwner(userId) && isValidClientUserUpdate(request.resource.data, resource.data));
    }

    match /complaints/{complaintId} {
      allow read: if isAdmin() || (isAuthenticated() && 'userId' in resource.data && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidComplaint(request.resource.data) && 'userId' in request.resource.data && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /wallet_transactions/{transactionId} {
      allow read: if isAdmin() || (isAuthenticated() && 'userId' in resource.data && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidWalletTransaction(request.resource.data) && 'userId' in request.resource.data && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if isAdmin() || (isAuthenticated() && 'userId' in resource.data && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidMessage(request.resource.data) && 'userId' in request.resource.data && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /streamAccess/{accessId} {
      allow read: if isAdmin() || (isAuthenticated() && 'userId' in resource.data && resource.data.userId == request.auth.uid);
      allow create: if isAuthenticated() && isValidStreamAccess(request.resource.data) && 'userId' in request.resource.data && request.resource.data.userId == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /agents/{agentId} {
      allow read: if true; // Public access for client store lookups
      allow create: if isOwner(agentId) && isValidAgent(request.resource.data) && request.resource.data.profit_balance == 0;
      allow update: if isAdmin() || (isOwner(agentId) && isValidAgent(request.resource.data) && request.resource.data.profit_balance == resource.data.profit_balance && request.resource.data.get('created_at', null) == resource.data.get('created_at', null));
      allow delete: if isAdmin();
    }

    match /agent_orders/{orderId} {
      allow read: if isAdmin() || (isAuthenticated() && 'agent_id' in resource.data && resource.data.agent_id == request.auth.uid);
      allow create: if isValidAgentOrder(request.resource.data);
      allow update: if isAdmin();
      allow delete: if isAdmin() || (isAuthenticated() && 'agent_id' in resource.data && resource.data.agent_id == request.auth.uid);
    }

    match /profit_requests/{requestId} {
      allow read: if isAdmin() || (isAuthenticated() && 'agent_id' in resource.data && resource.data.agent_id == request.auth.uid);
      allow create: if isAuthenticated() && isValidProfitRequest(request.resource.data) && 'agent_id' in request.resource.data && request.resource.data.agent_id == request.auth.uid;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /settings/{settingId} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
