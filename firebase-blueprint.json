{
  "entities": {
    "Bundle": {
      "title": "Data Bundle",
      "description": "A data bundle package offered for sale.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Display name of the bundle (e.g. 1GB Non-Expiry)" },
        "dataAmount": { "type": "string", "description": "Amount of data (e.g. 1GB)" },
        "price": { "type": "number", "description": "Price in GHS" },
        "network": { "type": "string", "enum": ["MTN", "Telecel", "AirtelTigo"], "description": "Network provider" },
        "active": { "type": "boolean", "description": "Whether the bundle is currently available" }
      },
      "required": ["name", "dataAmount", "price", "network"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order for a data bundle.",
      "type": "object",
      "properties": {
        "reference": { "type": "string", "description": "Paystack transaction reference" },
        "email": { "type": "string", "format": "email", "description": "Customer email" },
        "phone": { "type": "string", "description": "Customer phone number" },
        "network": { "type": "string", "description": "Selected network" },
        "bundle": { "type": "string", "description": "Selected data plan" },
        "amount": { "type": "number", "description": "Amount paid in GHS" },
        "status": { "type": "string", "enum": ["paid", "completed", "failed"], "description": "Order status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the order was created" }
      },
      "required": ["reference", "email", "phone", "network", "bundle", "amount", "status", "createdAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string", "description": "User's full name" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "walletBalance": { "type": "number", "description": "Current balance in Royal Wallet" }
      },
      "required": ["email", "fullName", "role"]
    },
    "WalletTransaction": {
      "title": "Wallet Transaction",
      "description": "A record of a wallet top-up or purchase.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["topup", "purchase"] },
        "status": { "type": "string", "enum": ["pending", "success", "failed"] },
        "reference": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "type", "status", "reference", "createdAt"]
    },
    "Message": {
      "title": "Support Message",
      "description": "A message from a user to the admin.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["unread", "read"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userEmail", "userName", "message", "status", "createdAt"]
    },
    "StreamAccess": {
      "title": "Stream Access",
      "description": "Access record for football streaming.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "revoked"] },
        "referenceCode": { "type": "string" },
        "amountPaid": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "userEmail", "status", "referenceCode", "amountPaid", "createdAt"]
    },
    "Agent": {
      "title": "Agent",
      "description": "Registered agent account details and settings.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agent_name": { "type": "string" },
        "agent_slug": { "type": "string" },
        "momo_name": { "type": "string" },
        "momo_number": { "type": "string" },
        "profit_balance": { "type": "number" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "agent_name", "agent_slug", "momo_name", "momo_number", "profit_balance", "created_at"]
    },
    "AgentOrder": {
      "title": "Agent Order",
      "description": "Order made via an agent store.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agent_id": { "type": "string" },
        "customer_details": { "type": "object" },
        "wholesale_price": { "type": "number" },
        "agent_price": { "type": "number" },
        "profit": { "type": "number" },
        "status": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "agent_id", "customer_details", "wholesale_price", "agent_price", "profit", "status", "created_at"]
    },
    "ProfitRequest": {
      "title": "Profit Request",
      "description": "withdrawal request of an agent's profit.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "agent_id": { "type": "string" },
        "withdrawal_amount": { "type": "number" },
        "status": { "type": "string" },
        "created_at": { "type": "string", "format": "date-time" }
      },
      "required": ["id", "agent_id", "withdrawal_amount", "status", "created_at"]
    }
  },
  "firestore": {
    "/bundles/{bundleId}": {
      "schema": "Bundle",
      "description": "Available data bundles."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and roles."
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Support messages."
    },
    "/streamAccess/{accessId}": {
      "schema": "StreamAccess",
      "description": "Football streaming access records."
    },
    "/wallet_transactions/{transactionId}": {
      "schema": "WalletTransaction",
      "description": "Records of wallet top-ups and purchases."
    },
    "/agents/{agentId}": {
      "schema": "Agent",
      "description": "Registered agents list and configurations."
    },
    "/agent_orders/{orderId}": {
      "schema": "AgentOrder",
      "description": "Agent store client order records."
    },
    "/profit_requests/{requestId}": {
      "schema": "ProfitRequest",
      "description": "Agent profit withdrawal requests."
    }
  }
}
