{
  "entities": {
    "Bundle": {
      "title": "Data Bundle",
      "description": "A data bundle package offered for sale.",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Display name of the bundle (e.g. 1GB Non-Expiry)" },
        "dataAmount": { "type": "string", "description": "Amount of data (e.g. 1GB)" },
        "price": { "type": "number", "description": "Price in GHS" },
        "network": { "type": "string", "enum": ["MTN", "Telecel", "AirtelTigo"], "description": "Network provider" },
        "active": { "type": "boolean", "description": "Whether the bundle is currently available" }
      },
      "required": ["name", "dataAmount", "price", "network"]
    },
    "Order": {
      "title": "Order",
      "description": "A customer order for a data bundle.",
      "type": "object",
      "properties": {
        "userId": { "type": "string", "description": "ID of the user who placed the order" },
        "customerName": { "type": "string", "description": "Customer's full name" },
        "recipientPhone": { "type": "string", "description": "Phone number to receive the data" },
        "recipientNetwork": { "type": "string", "description": "Recipient's network" },
        "bundleId": { "type": "string", "description": "ID of the purchased bundle" },
        "bundleName": { "type": "string", "description": "Name of the bundle at time of purchase" },
        "amountSent": { "type": "number", "description": "Amount sent by customer" },
        "referenceCode": { "type": "string", "description": "Payment reference code" },
        "status": { "type": "string", "enum": ["pending", "processing", "delivered", "cancelled"], "description": "Order status" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the order was placed" }
      },
      "required": ["userId", "customerName", "recipientPhone", "recipientNetwork", "bundleId", "amountSent", "referenceCode", "status", "createdAt"]
    },
    "UserProfile": {
      "title": "User Profile",
      "description": "User account information.",
      "type": "object",
      "properties": {
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string", "description": "User's full name" },
        "role": { "type": "string", "enum": ["admin", "user"] },
        "walletBalance": { "type": "number", "description": "Current balance in Royal Wallet" }
      },
      "required": ["email", "fullName", "role"]
    },
    "WalletTransaction": {
      "title": "Wallet Transaction",
      "description": "A record of a wallet top-up or purchase.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["topup", "purchase"] },
        "status": { "type": "string", "enum": ["pending", "success", "failed"] },
        "reference": { "type": "string" },
        "description": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "amount", "type", "status", "reference", "createdAt"]
    },
    "Message": {
      "title": "Support Message",
      "description": "A message from a user to the admin.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userEmail": { "type": "string" },
        "userName": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["unread", "read"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userEmail", "userName", "message", "status", "createdAt"]
    },
    "StreamAccess": {
      "title": "Stream Access",
      "description": "Access record for football streaming.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "userEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "revoked"] },
        "referenceCode": { "type": "string" },
        "amountPaid": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "userName", "userEmail", "status", "referenceCode", "amountPaid", "createdAt"]
    }
  },
  "firestore": {
    "/bundles/{bundleId}": {
      "schema": "Bundle",
      "description": "Available data bundles."
    },
    "/orders/{orderId}": {
      "schema": "Order",
      "description": "Customer orders."
    },
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "User profiles and roles."
    },
    "/messages/{messageId}": {
      "schema": "Message",
      "description": "Support messages."
    },
    "/streamAccess/{accessId}": {
      "schema": "StreamAccess",
      "description": "Football streaming access records."
    },
    "/wallet_transactions/{transactionId}": {
      "schema": "WalletTransaction",
      "description": "Records of wallet top-ups and purchases."
    }
  }
}
